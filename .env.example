# --- Local development ---
# Leave DATABASE_URL unset to use pglite (an embedded WASM Postgres in ./data/pgdata).
# Or set it to a real Postgres for local dev:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/audit
# Use 'pglite:./data/pgdata' to be explicit.
#
# DATABASE_URL=
# PGSSLMODE=require   # set this when DATABASE_URL points to Azure PG (TLS required)

# --- Storage (evidence files) ---
# In Azure: only AZURE_STORAGE_ACCOUNT is set, and Managed Identity authenticates.
# Locally with Azurite: leave both unset to use the well-known Azurite connection string,
# or set AZURE_STORAGE_CONNECTION_STRING explicitly.
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_CONNECTION_STRING=
EVIDENCE_CONTAINER=evidence

# --- Auth (Microsoft Entra ID — populated in Phase 0e) ---
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=                # `openssl rand -base64 32` then paste
# AZURE_AD_CLIENT_ID=
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_SECRET=         # omit if using Federated Identity Credential

# --- Engagement metadata ---
ENGAGEMENT_NAME="IT Audit — Local Dev"
